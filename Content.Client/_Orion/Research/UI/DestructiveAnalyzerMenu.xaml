<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
                      Title="{Loc 'research-machine-destructive-window-title'}"
                      SetSize="580 470"
                      MinSize="500 380">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
        <controls:StripeBack>
            <Label Name="ServerLabel" StyleClasses="LabelHeading" Margin="6 4"/>
        </controls:StripeBack>
        <RichTextLabel Name="BalanceLabel"/>
        <Button Name="ServerButton" Text="{Loc 'research-machine-common-server-list'}"/>

        <PanelContainer VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
                <Label Name="InsertedItemLabel"/>
                <SpriteView Name="InsertedItemSprite" SetSize="64 64" Scale="2 2" HorizontalAlignment="Center"/>
                <BoxContainer Name="MethodContainer" Orientation="Vertical">
                    <OptionButton Name="MethodOption"/>
                </BoxContainer>
                <Button Name="AnalyzeButton" Text="{Loc 'research-machine-destructive-run'}"/>
                <Button Name="EjectButton" Text="{Loc 'research-machine-eject-button'}"/>

                <controls:StripeBack>
                    <Label Text="{Loc 'research-machine-common-last-operation-title'}" StyleClasses="LabelSubText" Margin="6 2"/>
                </controls:StripeBack>
                <PanelContainer>
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#23232A" BorderThickness="1" BorderColor="#4A4A56"/>
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="6" SeparationOverride="2">
                        <RichTextLabel Name="LastSubjectLabel" HorizontalExpand="True"/>
                        <RichTextLabel Name="LastResultLabel" HorizontalExpand="True"/>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
