<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
                      Title="{Loc 'research-console-journal-window-title'}"
                      SetSize="620 520">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
        <Label Text="{Loc 'research-console-experiments-title'}" Modulate="#87CEFA"/>
        <PanelContainer MinHeight="220" VerticalExpand="True">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#23232A" BorderThickness="1" BorderColor="#4A4A56"/>
            </PanelContainer.PanelOverride>
            <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                <BoxContainer Name="ExperimentsContainer" Orientation="Vertical" Margin="6" SeparationOverride="4" HorizontalExpand="True"/>
            </ScrollContainer>
        </PanelContainer>
        <Label Text="{Loc 'research-console-journal-recent-logs'}" Modulate="#87CEFA"/>
        <PanelContainer MinHeight="130" VerticalExpand="True">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" BorderThickness="1" BorderColor="#4A4A56"/>
            </PanelContainer.PanelOverride>
            <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                <RichTextLabel Name="LogsLabel" Margin="6" HorizontalExpand="True" VerticalExpand="True"/>
            </ScrollContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
