<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
                      Title="{Loc 'research-server-control-title'}"
                      SetSize="620 560"
                      MinSize="520 420">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
        <controls:StripeBack>
            <Label Text="{Loc 'research-server-control-list-title'}" StyleClasses="LabelHeading" Margin="6 4"/>
        </controls:StripeBack>
        <PanelContainer VerticalExpand="True">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" BorderThickness="1" BorderColor="#4A4A56"/>
            </PanelContainer.PanelOverride>
            <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                <BoxContainer Name="ServerEntries" Orientation="Vertical" Margin="8" SeparationOverride="8"/>
            </ScrollContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
